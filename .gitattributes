# Default behavior: normalize all text files to LF
* text=auto eol=lf

# Source code files
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.prisma    text eol=lf
*.http      text eol=lf
*.env       text eol=lf
*.example   text eol=lf
*.toml      text eol=lf

# Shell scripts
*.sh        text eol=lf
*.bash      text eol=lf

# Binary files (Git, bunlara dokunma)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       text eol=lf
*.pdf       binary
*.zip       binary

# Lock files (auto-detect)
package-lock.json   text eol=lf
yarn.lock           text eol=lf
pnpm-lock.yaml      text eol=lf
